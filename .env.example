RDF_BASE_URL=https://rdf-przegladarka.ms.gov.pl/services/rdf/przegladarka-dokumentow-finansowych
REQUEST_TIMEOUT=30
MAX_CONNECTIONS=20
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
WORKERS=4

# --- Scraper ---
SCRAPER_DB_PATH=data/scraper.duckdb

# Storage backend: 'local' or 'gcs'
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=data/documents
STORAGE_GCS_BUCKET=rdf-documents-prod
STORAGE_GCS_PREFIX=krs/

# Scraper behavior
SCRAPER_ORDER_STRATEGY=priority_then_oldest
SCRAPER_DELAY_BETWEEN_KRS=2.0
SCRAPER_DELAY_BETWEEN_REQUESTS=0.5
SCRAPER_MAX_KRS_PER_RUN=0
SCRAPER_MAX_ERRORS_BEFORE_SKIP=3
SCRAPER_ERROR_BACKOFF_HOURS=24
SCRAPER_DOWNLOAD_TIMEOUT=60

# ---------------------------------------------------------------------------
# Batch runner
# ---------------------------------------------------------------------------
BATCH_USE_VPN=false
BATCH_WORKERS=3
BATCH_START_KRS=1
BATCH_CONCURRENCY_PER_WORKER=3
BATCH_DELAY_SECONDS=1.0

# Path to the existing DuckDB database file.
# The batch_progress table will be created here alongside financial data tables,
# so this should point to the same file used by the rest of the project.
BATCH_DB_PATH=data/scraper.duckdb

# NordVPN SOCKS5 - only required when BATCH_USE_VPN=true
# Service credentials (not your login password).
# Find at: nordaccount.com -> Services -> NordVPN -> Manual setup -> Credentials
NORDVPN_USERNAME=
NORDVPN_PASSWORD=
# JSON array of server hostnames (without .nordvpn.com suffix).
# Polish servers recommended for low latency to ms.gov.pl.
NORDVPN_SERVERS=["pl192", "pl193", "de887"]
