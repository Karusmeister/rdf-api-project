RDF_BASE_URL=https://rdf-przegladarka.ms.gov.pl/services/rdf/przegladarka-dokumentow-finansowych
REQUEST_TIMEOUT=30
MAX_CONNECTIONS=20
# JSON array of allowed origins. Defaults include localhost + Lovable.
# Override on Cloud Run: CORS_ORIGINS=["https://joy-forge-express.lovable.app","https://app.yourdomain.com"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173","http://127.0.0.1:3000","https://id-preview--aaed77c9-b864-4814-8747-ad97402d1f70.lovable.app","https://joy-forge-express.lovable.app"]
WORKERS=4

# --- Database ---
DATABASE_URL=postgresql://rdf:rdf_dev@localhost:5432/rdf

# Pipeline / analytics database (separate instance, keeps scraper workload isolated)
PIPELINE_DATABASE_URL=postgresql://rdf:rdf_dev@localhost:5433/pipeline

# --- Pipeline / BigQuery (used by pipeline-runner Cloud Run Job) ---
GCP_PROJECT_ID=rdf-api-project
BQ_DATASET=rdf_analytics
BQ_LOCATION=europe-central2
PIPELINE_GCS_BUCKET=rdf-pipeline-staging

# Storage backend: 'local' or 'gcs'
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=data/documents
STORAGE_GCS_BUCKET=rdf-documents-prod
STORAGE_GCS_PREFIX=krs/

# Scraper behavior
SCRAPER_ORDER_STRATEGY=priority_then_oldest
SCRAPER_DELAY_BETWEEN_KRS=2.0
SCRAPER_DELAY_BETWEEN_REQUESTS=0.5
SCRAPER_MAX_KRS_PER_RUN=0
SCRAPER_MAX_ERRORS_BEFORE_SKIP=3
SCRAPER_ERROR_BACKOFF_HOURS=24
SCRAPER_DOWNLOAD_TIMEOUT=60

# ---------------------------------------------------------------------------
# Batch runner
# ---------------------------------------------------------------------------
BATCH_USE_VPN=false
BATCH_WORKERS=3
BATCH_START_KRS=1
BATCH_CONCURRENCY_PER_WORKER=3
BATCH_DELAY_SECONDS=1.0

# NordVPN SOCKS5 - only required when BATCH_USE_VPN=true
# Service credentials (not your login password).
# Find at: nordaccount.com -> Services -> NordVPN -> Manual setup -> Credentials
NORDVPN_USERNAME=
NORDVPN_PASSWORD=
# JSON array of server hostnames (without .nordvpn.com suffix).
# Polish servers recommended for low latency to ms.gov.pl.
NORDVPN_SERVERS=["pl192", "pl193", "de887"]

# ---------------------------------------------------------------------------
# Auth / JWT
# ---------------------------------------------------------------------------
# ENVIRONMENT controls JWT secret enforcement. In staging/production, a
# non-default JWT_SECRET with >=32 bytes of entropy is required or the app
# will refuse to start.
#   Generate one: python -c "import secrets; print(secrets.token_hex(32))"
ENVIRONMENT=local
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
GOOGLE_CLIENT_ID=
# Must be smtp in staging/production; app startup fails if set to log outside local.
VERIFICATION_EMAIL_MODE=log
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# reCAPTCHA v3 — required in staging/production unless AUTH_REQUIRE_CAPTCHA_IN_NONLOCAL=false
RECAPTCHA_SECRET_KEY=
AUTH_REQUIRE_CAPTCHA_IN_NONLOCAL=true

# Frontend URL for password-reset email links.
# Must be https:// and non-localhost in staging/production.
FRONTEND_URL=http://localhost:5173
