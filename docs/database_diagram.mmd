erDiagram
    %% ============================================================
    %% SCRAPER LAYER (app/scraper/db.py)
    %% ============================================================

    krs_registry {
        VARCHAR_10 krs PK
        VARCHAR company_name
        VARCHAR legal_form
        BOOLEAN is_active
        TIMESTAMP first_seen_at
        TIMESTAMP last_checked_at
        TIMESTAMP last_download_at
        INTEGER check_priority
        INTEGER check_error_count
        VARCHAR last_error_message
        INTEGER total_documents
        INTEGER total_downloaded
    }

    krs_documents {
        VARCHAR document_id PK
        VARCHAR_10 krs FK
        VARCHAR rodzaj
        VARCHAR status
        VARCHAR nazwa
        VARCHAR okres_start
        VARCHAR okres_end
        VARCHAR filename
        BOOLEAN is_ifrs
        BOOLEAN is_correction
        VARCHAR date_filed
        VARCHAR date_prepared
        BOOLEAN is_downloaded
        TIMESTAMP downloaded_at
        VARCHAR storage_path
        VARCHAR storage_backend
        BIGINT file_size_bytes
        BIGINT zip_size_bytes
        INTEGER file_count
        VARCHAR file_types
        TIMESTAMP discovered_at
        TIMESTAMP metadata_fetched_at
        VARCHAR download_error
    }

    scraper_runs {
        VARCHAR run_id PK
        TIMESTAMP started_at
        TIMESTAMP finished_at
        VARCHAR status
        VARCHAR mode
        INTEGER krs_checked
        INTEGER krs_new_found
        INTEGER documents_discovered
        INTEGER documents_downloaded
        INTEGER documents_failed
        BIGINT bytes_downloaded
        VARCHAR config_snapshot
        VARCHAR error_message
    }

    %% ============================================================
    %% KRS ENTITY LAYER (app/repositories/krs_repo.py)
    %% ============================================================

    krs_entities {
        VARCHAR_10 krs PK
        VARCHAR name
        VARCHAR legal_form
        VARCHAR status
        DATE registered_at
        DATE last_changed_at
        VARCHAR_13 nip
        VARCHAR_14 regon
        VARCHAR address_city
        VARCHAR address_street
        VARCHAR address_postal_code
        JSON raw
        VARCHAR source
        TIMESTAMP synced_at
    }

    krs_sync_log {
        INTEGER id PK
        TIMESTAMP started_at
        TIMESTAMP finished_at
        INTEGER krs_count
        INTEGER new_count
        INTEGER updated_count
        INTEGER error_count
        VARCHAR source
        VARCHAR status
    }

    krs_scan_cursor {
        BOOLEAN id PK
        INTEGER next_krs_int
        TIMESTAMP updated_at
    }

    krs_scan_runs {
        INTEGER id PK
        TIMESTAMP started_at
        TIMESTAMP finished_at
        VARCHAR status
        INTEGER krs_from
        INTEGER krs_to
        INTEGER probed_count
        INTEGER valid_count
        INTEGER error_count
        VARCHAR stopped_reason
    }

    %% ============================================================
    %% BATCH LAYER (batch/progress.py)
    %% ============================================================

    batch_progress {
        BIGINT krs PK
        VARCHAR status
        INTEGER worker_id
        TIMESTAMP processed_at
    }

    %% ============================================================
    %% PREDICTION LAYER 1 — Entities (app/db/prediction_db.py)
    %% ============================================================

    data_sources {
        VARCHAR id PK
        VARCHAR name
        VARCHAR description
        VARCHAR base_url
        BOOLEAN is_active
        TIMESTAMP created_at
    }

    companies {
        VARCHAR_10 krs PK
        VARCHAR_13 nip
        VARCHAR_14 regon
        VARCHAR_10 pkd_code
        DATE incorporation_date
        VARCHAR voivodeship
        TIMESTAMP updated_at
    }

    company_identifiers {
        INTEGER id PK
        VARCHAR_10 krs FK
        VARCHAR data_source_id FK
        VARCHAR identifier_type
        VARCHAR identifier_value
        DATE valid_from
        DATE valid_to
        TIMESTAMP created_at
    }

    %% ============================================================
    %% PREDICTION LAYER 2 — Financial Data
    %% ============================================================

    financial_reports {
        VARCHAR id PK
        VARCHAR logical_key
        INTEGER report_version
        VARCHAR supersedes_report_id FK
        VARCHAR_10 krs FK
        VARCHAR data_source_id FK
        VARCHAR report_type
        INTEGER fiscal_year
        DATE period_start
        DATE period_end
        VARCHAR taxonomy_version
        VARCHAR source_document_id FK
        VARCHAR source_file_path
        VARCHAR ingestion_status
        VARCHAR ingestion_error
        TIMESTAMP created_at
    }

    raw_financial_data {
        VARCHAR report_id FK
        VARCHAR section
        INTEGER extraction_version
        JSON data_json
        VARCHAR taxonomy_version
        TIMESTAMP created_at
    }

    financial_line_items {
        VARCHAR report_id FK
        VARCHAR section
        VARCHAR tag_path
        INTEGER extraction_version
        VARCHAR label_pl
        DOUBLE value_current
        DOUBLE value_previous
        VARCHAR currency
    }

    %% ============================================================
    %% PREDICTION LAYER 3 — Features
    %% ============================================================

    feature_definitions {
        VARCHAR id PK
        VARCHAR name
        VARCHAR description
        VARCHAR category
        VARCHAR formula_description
        VARCHAR formula_numerator
        VARCHAR formula_denominator
        JSON required_tags
        VARCHAR computation_logic
        INTEGER version
        BOOLEAN is_active
        TIMESTAMP created_at
    }

    feature_sets {
        VARCHAR id PK
        VARCHAR name
        VARCHAR description
        BOOLEAN is_active
        TIMESTAMP created_at
    }

    feature_set_members {
        VARCHAR feature_set_id FK
        VARCHAR feature_definition_id FK
        INTEGER ordinal
    }

    computed_features {
        VARCHAR report_id FK
        VARCHAR feature_definition_id FK
        VARCHAR_10 krs FK
        INTEGER fiscal_year
        DOUBLE value
        BOOLEAN is_valid
        VARCHAR error_message
        INTEGER source_extraction_version
        INTEGER computation_version
        TIMESTAMP computed_at
    }

    %% ============================================================
    %% PREDICTION LAYER 4 — Models & Predictions
    %% ============================================================

    model_registry {
        VARCHAR id PK
        VARCHAR name
        VARCHAR model_type
        VARCHAR version
        VARCHAR feature_set_id FK
        VARCHAR description
        JSON hyperparameters
        JSON training_metrics
        TIMESTAMP training_date
        JSON training_data_spec
        VARCHAR artifact_path
        BOOLEAN is_active
        BOOLEAN is_baseline
        TIMESTAMP created_at
    }

    prediction_runs {
        VARCHAR id PK
        VARCHAR model_id FK
        TIMESTAMP run_date
        JSON parameters
        INTEGER companies_scored
        VARCHAR status
        VARCHAR error_message
        DOUBLE duration_seconds
        TIMESTAMP created_at
    }

    predictions {
        VARCHAR id PK
        VARCHAR prediction_run_id FK
        VARCHAR_10 krs FK
        VARCHAR report_id FK
        DOUBLE raw_score
        DOUBLE probability
        SMALLINT classification
        VARCHAR risk_category
        JSON feature_contributions
        TIMESTAMP created_at
    }

    %% ============================================================
    %% PREDICTION LAYER 5 — Ground Truth
    %% ============================================================

    bankruptcy_events {
        VARCHAR id PK
        VARCHAR_10 krs FK
        VARCHAR event_type
        DATE event_date
        VARCHAR data_source_id FK
        VARCHAR court_case_ref
        VARCHAR announcement_id
        BOOLEAN is_confirmed
        VARCHAR notes
        TIMESTAMP created_at
    }

    %% ============================================================
    %% Job Tracking
    %% ============================================================

    assessment_jobs {
        VARCHAR id PK
        VARCHAR_10 krs FK
        VARCHAR status
        VARCHAR stage
        VARCHAR error_message
        JSON result_json
        TIMESTAMP created_at
        TIMESTAMP updated_at
    }

    %% ============================================================
    %% RELATIONSHIPS
    %% Solid lines = enforced by app logic (no DB FK constraints)
    %% All relationships are inferred from column naming + app code
    %% ============================================================

    %% -- Scraper layer --
    krs_registry ||--o{ krs_documents : "krs (app-enforced)"

    %% -- KRS entity ↔ scraper cross-reference --
    krs_registry ||--o| krs_entities : "krs (same entity)"
    krs_registry ||--o| companies : "krs (enrichment)"

    %% -- KRS entity ↔ batch progress --
    krs_entities ||--o| batch_progress : "krs (probed integer)"

    %% -- Prediction Layer 1 --
    companies ||--o{ company_identifiers : "krs"
    data_sources ||--o{ company_identifiers : "data_source_id"

    %% -- Prediction Layer 2 --
    companies ||--o{ financial_reports : "krs"
    data_sources ||--o{ financial_reports : "data_source_id"
    krs_documents ||--o| financial_reports : "source_document_id"
    financial_reports ||--o| financial_reports : "supersedes_report_id (self-ref)"
    financial_reports ||--o{ raw_financial_data : "report_id"
    financial_reports ||--o{ financial_line_items : "report_id"

    %% -- Prediction Layer 3 --
    feature_sets ||--o{ feature_set_members : "feature_set_id"
    feature_definitions ||--o{ feature_set_members : "feature_definition_id"
    financial_reports ||--o{ computed_features : "report_id"
    feature_definitions ||--o{ computed_features : "feature_definition_id"
    companies ||--o{ computed_features : "krs"

    %% -- Prediction Layer 4 --
    feature_sets ||--o| model_registry : "feature_set_id"
    model_registry ||--o{ prediction_runs : "model_id"
    prediction_runs ||--o{ predictions : "prediction_run_id"
    companies ||--o{ predictions : "krs"
    financial_reports ||--o{ predictions : "report_id"

    %% -- Prediction Layer 5 --
    companies ||--o{ bankruptcy_events : "krs"
    data_sources ||--o{ bankruptcy_events : "data_source_id"

    %% -- Job tracking --
    companies ||--o{ assessment_jobs : "krs"
